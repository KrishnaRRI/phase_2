class Graph:
    def __init__(self):
        self.graph = {}

    def dfs(self,start):
        stack = [start]
        visited = []

        while stack:
            cur = stack.pop()
            if cur not in visited:
                visited.append(cur)
                stack.extend(self.graph[cur])
        print(visited)

    def bfs(self, start):
        Queue = [start]
        visited = []

        while Queue:
            cur = Queue.pop(0)
            if cur not in visited:
                visited.append(cur)
                Queue.extend(self.graph[cur])
        print(visited)




    def insert(self,s,d):
        for i in range(2):
            if s in self.graph:
                self.graph[s].append(d)
            else:
                self.graph[s]= [d]
            s , d = d, s




